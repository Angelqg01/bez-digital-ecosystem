{
  "name": "bezhas-security-scripts",
  "version": "1.0.0",
  "description": "Security monitoring and dependency management scripts for BeZhas",
  "private": true,
  "scripts": {
    "test-discord": "node testDiscord.js",
    "security-check": "node securityMonitor.js",
