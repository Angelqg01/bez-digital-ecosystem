{
  "name": "bezhas-hub",
  "version": "1.0.0",
  "description": "Smart Contracts for Bezhas Social Network",
  "main": "index.js",
  "scripts": {
    "test": "forge test",
    "test:backend": "cd backend && pnpm test",
    "test:all": "pnpm test && cd backend && pnpm test",
    "start:backend": "node backend/server.js",
    "start:frontend": "cd frontend && pnpm dev",
    "start:dev": "concurrently \"pnpm start:backend\" \"pnpm start:frontend\"",
    "dev": "pnpm start:dev",
    "build:frontend": "cd frontend && pnpm build",
    "build:backend:docker": "docker build -t bezhas-backend -f backend/Dockerfile.optimized backend/",
    "build:frontend:docker": "docker build -t bezhas-frontend -f frontend/Dockerfile.optimized frontend/",
    "build:docker": "pnpm build:backend:docker && pnpm build:frontend:docker",
    "validate:deploy": "node scripts/validate-deployment.js",
    "smoke:online": "node scripts/smoke-online.js",
    "scan:secrets": "node scripts/scan-secrets.js",
    "grant:bridge:roles": "hardhat run scripts/grant-bridge-roles.js --network localhost",
    "dev:up": "docker compose up -d",
    "dev:down": "docker compose down",
    "dev:logs": "docker compose logs -f",
    "prod:up": "docker compose -f docker-compose.gcp.yml up -d",
    "prod:down": "docker compose -f docker-compose.gcp.yml down",
    "deploy:dao": "hardhat run scripts/deploy-dao.js --network localhost",
    "deploy:quality-oracle": "hardhat run scripts/deploy-quality-oracle.js --network amoy",
    "deploy:quality-oracle:polygon": "hardhat run scripts/deploy-quality-oracle.js --network polygon",
    "deploy:mainnet-core": "hardhat run scripts/deploy-mainnet-core.js --network polygon",
    "deploy:mainnet-core:dry": "TREASURY_WALLET=0x52Df82920CBAE522880dD7657e43d1A754eD044E hardhat run scripts/deploy-mainnet-core.js --network polygon",
    "admin:activate-wallets": "node scripts/activate-admin-wallets.js",
    "admin:activate-wallets:execute": "node scripts/activate-admin-wallets.js --execute",
    "test:orchestrator-e2e": "node scripts/test-orchestrator-e2e.js",
    "test:orchestrator-e2e:fast": "node scripts/test-orchestrator-e2e.js --fast",
    "sdk:publish-npm": "cd sdk && pnpm publish --access public",
    "sdk:publish-pnpm": "cd sdk && pnpm publish --access public --no-git-checks",
    "sdk:publish-all": "pnpm sdk:publish-npm && pnpm sdk:publish-npm",
    "gcp:deploy": "gcloud builds submit --config=cloudbuild.yaml",
    "gcp:deploy:backend": "gcloud builds submit --config=cloudbuild.yaml --substitutions=_TAG=v$(date +%Y%m%d)",
    "deploy:farming": "hardhat run scripts/deploy-liquidity-farming.js --network localhost",
    "deploy:farming:amoy": "hardhat run scripts/deploy-liquidity-farming.js --network amoy",
    "deploy:farming:polygon": "hardhat run scripts/deploy-liquidity-farming.js --network polygon",
    "test:sdk": "node sdk/test-contracts-sdk.js",
    "check-balance": "hardhat run scripts/check-balance.js --network amoy",
    "check-safe": "hardhat run scripts/check-safe-balance.js --network amoy",
    "transfer-from-safe": "hardhat run scripts/transfer-from-safe.js --network amoy",
    "verify-deployment": "hardhat run scripts/verify-deployment.js --network amoy",
    "simulate-quality-oracle": "node scripts/simulate-quality-oracle.js",
    "compile": "forge build",
    "bez:info": "node scripts/show-bez-info.js",
    "bez:verify": "node scripts/verify-contract-address.js",
    "lint": "cd frontend && pnpm lint",
    "clean": "rimraf node_modules backend/node_modules frontend/node_modules",
    "install:all": "pnpm install && cd backend && pnpm install && cd ../frontend && pnpm install",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "web3",
    "polygon",
    "social"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@playwright/test": "^1.41.0",
    "concurrently": "^9.2.1",
    "ethers": "6.16.0",
    "hardhat": "^2.22.19",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@adraffy/ens-normalize": "^1.11.1",
    "@chainlink/contracts": "^1.5.0",
    "@chainlink/contracts-ccip": "^1.6.4",
    "@openzeppelin/contracts": "^5.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  },
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "pnpm": ">=11"
  }
}
