POLYGON_RPC_URL=https://polygon-bor.publicnode.com
BEZ_TOKEN_ADDRESS=0xEcBa873B534C54DE2B62acDE232ADCa4369f11A8

# Backend under test
E2E_BACKEND_URL=http://127.0.0.1:8080

# Buyer wallet that signs approve() and holds USDT/USDC + MATIC gas.
E2E_BUYER_PRIVATE_KEY=
E2E_CURRENCY=USDC
E2E_AMOUNT=0.1

# Backend hot wallet / spender. Must match the backend HOT_WALLET_PRIVATE_KEY address.
E2E_HOT_WALLET_ADDRESS=

# Required unless the backend is started with NODE_ENV=development and AUTH_BYPASS_ENABLED=true.
E2E_AUTH_TOKEN=
